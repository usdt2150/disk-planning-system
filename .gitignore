# Exclude specific large or generated files
package-lock.json

# Keep important configuration and source files
# The following are NOT ignored:
# - *.py (source code)
# - *.vue (Vue components)
# - *.js (JavaScript source)
# - *.json (config files like package.json, config.json)
# - *.md (documentation)
# - *.html (templates)
# - *.css, *.scss (styles)
# - Dockerfile
# - docker-compose.yml
# - requirements.txt